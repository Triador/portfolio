---
import Layout from '../layouts/Layout.astro';
---

<Layout title="triador — разработчик" description="Создаю инструменты, которые делают жизнь удобнее.">
  <main>

    <!-- NAV -->
    <nav>
      <span class="nav-logo">triador<span class="blink">_</span></span>
      <div class="nav-links">
        <a href="#projects">проекты</a>
        <a href="https://github.com/triador" target="_blank" rel="noopener">github</a>
      </div>
    </nav>

    <!-- HERO -->
    <section class="hero">
      <div class="container">
        <p class="hero-label">👋 привет</p>
        <h1 class="hero-title">Я <span class="accent">triador</span></h1>
        <p class="hero-sub">
          Делаю продукты, которые экономят время мне.<br/>
          Возможно, сэкономят и вам.
        </p>
      </div>
    </section>

    <!-- PROJECTS -->
    <section id="projects" class="section">
      <div class="container">
        <h2 class="section-title">Проекты</h2>

        <div class="project-card">
          <div class="project-header">
            <div>
              <h3 class="project-name">Finance Manager</h3>
              <p class="project-tagline">Бот в Telegram для учёта общих расходов</p>
            </div>
            <div class="project-badge">
              <span class="status-dot"></span> работает
            </div>
          </div>

          <p class="project-desc">
            Ходили с друзьями в кафе или снимали квартиру вскладчину?
            Этот бот сам считает, кто кому сколько должен.
            Один заплатил за всех — просто скажи боту, и он всё распределит.
            Никаких таблиц Excel, никакой путаницы в переписке.
          </p>

          <div class="features-list">
            <div class="feature-item">
              <span class="feature-icon">💸</span>
              <div>
                <div class="feature-title">Записывает расходы</div>
                <div class="feature-desc">Кто заплатил, за кого и сколько — всё фиксируется в одном месте.</div>
              </div>
            </div>
            <div class="feature-item">
              <span class="feature-icon">⚖️</span>
              <div>
                <div class="feature-title">Делит по-честному</div>
                <div class="feature-desc">Один купил — расходы поровну на всех. Копейка в копейку.</div>
              </div>
            </div>
            <div class="feature-item">
              <span class="feature-icon">🔁</span>
              <div>
                <div class="feature-title">Убирает лишние долги</div>
                <div class="feature-desc">Если Вася должен Пете, а Петя — Васе, бот сам это заметит и зачтёт.</div>
              </div>
            </div>
            <div class="feature-item">
              <span class="feature-icon">📊</span>
              <div>
                <div class="feature-title">Показывает картину целиком</div>
                <div class="feature-desc">В любой момент видно, кто кому и сколько должен в группе.</div>
              </div>
            </div>
            <div class="feature-item">
              <span class="feature-icon">📅</span>
              <div>
                <div class="feature-title">Помнит историю</div>
                <div class="feature-desc">Все операции сохраняются. Можно посмотреть расходы за любой месяц.</div>
              </div>
            </div>
          </div>

          <div class="project-footer">
            <a href={`${import.meta.env.BASE_URL}/tech`} class="btn-secondary">технические детали →</a>
            <a href="https://github.com/triador/finance-manager" target="_blank" rel="noopener" class="btn-outline">
              исходный код →
            </a>
          </div>
        </div>

        <!-- PROJECT CARD: grindbot -->
        <div class="project-card">
          <div class="project-header">
            <div>
              <h3 class="project-name">Grindbot</h3>
              <p class="project-tagline">Торговый бот для биржи Bybit</p>
            </div>
            <div class="project-badge">
              <span class="status-dot"></span> работает
            </div>
          </div>

          <p class="project-desc">
            Бот, который торгует криптовалютой вместо вас — пока вы спите или занимаетесь своими делами.
            Он расставляет ордера на покупку и продажу по сетке цен и зарабатывает на колебаниях курса.
            Не нужно следить за рынком: бот сам реагирует на движение цены и перестраивается.
          </p>

          <div class="features-list">
            <div class="feature-item">
              <span class="feature-icon">📐</span>
              <div>
                <div class="feature-title">Сеточная стратегия</div>
                <div class="feature-desc">Покупает дешевле, продаёт дороже — снова и снова, на каждом колебании цены.</div>
              </div>
            </div>
            <div class="feature-item">
              <span class="feature-icon">🔄</span>
              <div>
                <div class="feature-title">Адаптируется к рынку</div>
                <div class="feature-desc">Если цена уходит за пределы сетки, бот перестраивает позиции и продолжает работу.</div>
              </div>
            </div>
            <div class="feature-item">
              <span class="feature-icon">💤</span>
              <div>
                <div class="feature-title">Работает круглосуточно</div>
                <div class="feature-desc">Не устаёт, не отвлекается и не пропускает сделки. Биржа никогда не спит — бот тоже.</div>
              </div>
            </div>
            <div class="feature-item">
              <span class="feature-icon">💰</span>
              <div>
                <div class="feature-title">Деньги не простаивают</div>
                <div class="feature-desc">Свободные средства отправляются в накопительный продукт биржи и продолжают работать.</div>
              </div>
            </div>
          </div>

          <div class="project-footer">
            <a href={`${import.meta.env.BASE_URL}/tech-grindbot`} class="btn-secondary">технические детали →</a>
          </div>
        </div>

        <!-- PROJECT CARD: bookey -->
        <div class="project-card">
          <div class="project-header">
            <div>
              <h3 class="project-name">Bookey</h3>
              <p class="project-tagline">Сервис для ведения списка книг</p>
            </div>
            <div class="project-badge">
              <span class="status-dot"></span> работает
            </div>
          </div>

          <p class="project-desc">
            Личная полка в интернете: добавляй книги, отмечай прочитанные, оставляй заметки и отзывы.
            Можно искать книги через Google Books, импортировать с Litres и Goodreads,
            а ещё участвовать в марафонах чтения вместе с другими.
          </p>

          <div class="features-list">
            <div class="feature-item">
              <span class="feature-icon">📚</span>
              <div>
                <div class="feature-title">Личная полка</div>
                <div class="feature-desc">Читаю, прочитал, хочу прочитать — книги разложены по разделам.</div>
              </div>
            </div>
            <div class="feature-item">
              <span class="feature-icon">🔍</span>
              <div>
                <div class="feature-title">Поиск и импорт</div>
                <div class="feature-desc">Ищи через Google Books или добавляй прямо со страницы книги на Litres и Goodreads.</div>
              </div>
            </div>
            <div class="feature-item">
              <span class="feature-icon">⭐</span>
              <div>
                <div class="feature-title">Отзывы и оценки</div>
                <div class="feature-desc">Ставь оценки, пиши рецензии и личные заметки к каждой книге.</div>
              </div>
            </div>
            <div class="feature-item">
              <span class="feature-icon">🏃</span>
              <div>
                <div class="feature-title">Марафоны чтения</div>
                <div class="feature-desc">Читай книги вместе с другими участниками, обсуждай прямо внутри марафона.</div>
              </div>
            </div>
          </div>

          <div class="project-footer">
            <a href={`${import.meta.env.BASE_URL}/tech-bookey`} class="btn-secondary">технические детали →</a>
          </div>
        </div>

      </div>
    </section>

    <!-- FOOTER -->
    <footer>
      <div class="container footer-inner">
        <span class="muted">сделано с душой</span>
        <a href="https://github.com/triador" target="_blank" rel="noopener">github.com/triador</a>
      </div>
    </footer>

  </main>
</Layout>

<style>
  .container {
    max-width: 860px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* ── Nav ── */
  nav {
    position: sticky;
    top: 0;
    z-index: 10;
    background: rgba(13, 17, 23, 0.85);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--border);
    padding: 14px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-logo {
    font-size: 16px;
    font-weight: 700;
    color: var(--text);
  }

  .blink {
    animation: blink 1s step-end infinite;
    color: var(--green);
  }
  @keyframes blink {
    50% { opacity: 0; }
  }

  .nav-links {
    display: flex;
    gap: 24px;
  }
  .nav-links a {
    color: var(--muted);
    font-size: 13px;
    transition: color 0.2s;
  }
  .nav-links a:hover {
    color: var(--text);
    text-decoration: none;
  }

  /* ── Hero ── */
  .hero {
    padding: 80px 0 60px;
  }

  .hero-label {
    font-size: 18px;
    margin-bottom: 16px;
  }

  .hero-title {
    font-size: clamp(28px, 5vw, 48px);
    font-weight: 700;
    margin-bottom: 20px;
    line-height: 1.2;
  }

  .accent {
    color: var(--cyan);
  }

  .hero-sub {
    color: var(--muted);
    font-size: 15px;
    line-height: 1.9;
    max-width: 520px;
  }

  /* ── Section ── */
  .section {
    padding: 64px 0;
    border-top: 1px solid var(--border);
  }

  .section-title {
    font-size: 22px;
    font-weight: 700;
    margin-bottom: 28px;
    color: var(--text);
  }

  /* ── About ── */
  .about-text p {
    color: var(--muted);
    font-size: 14px;
    line-height: 1.9;
    max-width: 620px;
  }
  .about-text p + p {
    margin-top: 16px;
  }

  /* ── Project card ── */
  .project-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .project-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 16px;
  }

  .project-name {
    font-size: 20px;
    font-weight: 700;
    color: var(--text);
  }

  .project-tagline {
    color: var(--muted);
    font-size: 13px;
    margin-top: 4px;
  }

  .project-badge {
    display: flex;
    align-items: center;
    gap: 6px;
    color: var(--green);
    font-size: 12px;
    white-space: nowrap;
    border: 1px solid var(--green);
    padding: 4px 10px;
    border-radius: 20px;
    background: #3fb95010;
  }

  .status-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--green);
    animation: pulse 2s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.4; }
  }

  .project-desc {
    color: var(--muted);
    font-size: 14px;
    line-height: 1.9;
  }

  /* ── Features ── */
  .features-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .feature-item {
    display: flex;
    gap: 14px;
    align-items: flex-start;
  }

  .feature-icon {
    font-size: 22px;
    flex-shrink: 0;
    line-height: 1;
    margin-top: 1px;
  }

  .feature-title {
    font-weight: 600;
    font-size: 14px;
    margin-bottom: 2px;
    color: var(--text);
  }

  .feature-desc {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.6;
  }

  /* ── Project footer ── */
  .project-footer {
    display: flex;
    justify-content: flex-end;
    gap: 12px;
    flex-wrap: wrap;
  }

  .btn-outline {
    display: inline-block;
    border: 1px solid var(--border);
    color: var(--text);
    padding: 8px 18px;
    border-radius: 6px;
    font-size: 13px;
    transition: border-color 0.2s, color 0.2s;
  }
  .btn-outline:hover {
    border-color: var(--cyan);
    color: var(--cyan);
    text-decoration: none;
  }

  .btn-secondary {
    display: inline-block;
    border: 1px solid var(--border);
    color: var(--muted);
    padding: 8px 18px;
    border-radius: 6px;
    font-size: 13px;
    transition: border-color 0.2s, color 0.2s;
  }
  .btn-secondary:hover {
    border-color: var(--muted);
    color: var(--text);
    text-decoration: none;
  }

  /* ── Footer ── */
  footer {
    border-top: 1px solid var(--border);
    padding: 24px;
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
    font-size: 12px;
  }

  .muted { color: var(--muted); }

  /* ── Responsive ── */
  @media (max-width: 640px) {
    .project-header {
      flex-direction: column;
    }
    .project-footer {
      justify-content: flex-start;
    }
    .footer-inner {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
