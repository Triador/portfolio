---
const base = import.meta.env.BASE_URL;
---
<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8" />
  <noscript><meta http-equiv="refresh" content={`0;url=${base}/ru/`} /></noscript>
  <script define:vars={{ base }}>
    const lang = navigator.language?.toLowerCase().startsWith('ru') ? 'ru' : 'en';
    window.location.replace(base + '/' + lang + '/');
  </script>
</head>
<body></body>
</html>
