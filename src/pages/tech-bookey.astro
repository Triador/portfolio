---
import Layout from '../layouts/Layout.astro';
import Terminal from '../components/Terminal.astro';
import Badge from '../components/Badge.astro';

const techStack = [
  { name: 'Java 11', color: 'orange' },
  { name: 'Spring Boot 2', color: 'green' },
  { name: 'PostgreSQL', color: 'cyan' },
  { name: 'Spring Security', color: 'red' },
  { name: 'WebSocket', color: 'purple' },
  { name: 'Liquibase', color: 'yellow' },
  { name: 'QueryDSL', color: 'cyan' },
  { name: 'Caffeine Cache', color: 'green' },
  { name: 'AWS S3', color: 'orange' },
  { name: 'Docker', color: 'cyan' },
] as const;

const features = [
  {
    icon: '📚',
    title: 'Bookshelf Sections',
    desc: 'Books organized by status: reading, completed, want-to-read, etc. Per-user bookshelf with section stats.',
  },
  {
    icon: '🔍',
    title: 'Multi-source Search',
    desc: 'Full-text search in own DB + Google Books API. Parsers for Litres and Goodreads — add books from URLs.',
  },
  {
    icon: '⭐',
    title: 'Reviews & Ratings',
    desc: 'User reviews and star ratings per book. Hourly cron job recalculates book aggregate rating.',
  },
  {
    icon: '🏃',
    title: 'Reading Marathons',
    desc: 'Group reading challenges with chat, progress tracking, and book-completion marks. Rate limit: 10 msg/min.',
  },
  {
    icon: '🔐',
    title: 'Auth: Social + JWT',
    desc: 'Email/password + OAuth2 (Google, Facebook, VK, Yandex, Telegram). JWT access (10h) + refresh (20d) tokens.',
  },
  {
    icon: '🤖',
    title: 'AI Integration',
    desc: 'Gemini AI API for book prompts and recommendations. Cached responses to reduce API usage.',
  },
  {
    icon: '📬',
    title: 'Telegram Bot',
    desc: 'Webhook-based Telegram integration. Users can subscribe to notifications and interact via bot.',
  },
  {
    icon: '🖼️',
    title: 'Image Storage',
    desc: 'Book covers and user avatars stored in DigitalOcean Spaces (S3-compatible). Auto-resize on upload.',
  },
];

const stats = [
  { label: 'Language', value: 'Java 11' },
  { label: 'Framework', value: 'Spring Boot 2.2' },
  { label: 'Database', value: 'PostgreSQL' },
  { label: 'Port', value: ':8081' },
  { label: 'Auth', value: 'JWT + OAuth2' },
  { label: 'Storage', value: 'DO Spaces (S3)' },
];
---

<Layout title="bookey — technical details" description="Technical implementation details for the Bookey book management service.">
  <main>

    <!-- NAV -->
    <nav>
      <a href={`${import.meta.env.BASE_URL}/`} class="nav-logo">triador<span class="blink">_</span></a>
      <div class="nav-links">
        <a href={`${import.meta.env.BASE_URL}/`}>← главная</a>
        <a href="https://github.com/triador" target="_blank" rel="noopener">github</a>
      </div>
    </nav>

    <!-- HEADER -->
    <section class="page-header">
      <div class="container">
        <p class="page-label"><span class="muted">~/projects/</span>bookey</p>
        <h1 class="page-title">Technical Details</h1>
        <p class="page-sub">Book management & social reading platform</p>
      </div>
    </section>

    <!-- CONTENT -->
    <section class="section">
      <div class="container">

        <!-- Stack -->
        <div class="block">
          <h2 class="block-title"><span class="muted">##</span> stack</h2>
          <div class="tech-badges">
            {techStack.map(t => <Badge text={t.name} color={t.color} />)}
          </div>
        </div>

        <!-- Architecture -->
        <div class="block">
          <h2 class="block-title"><span class="muted">##</span> architecture</h2>
          <Terminal title="layers" lines={[
            { text: '<span style="color:var(--muted)">// layered architecture</span>' },
            { text: '' },
            { text: '<span style="color:var(--cyan)">REST Controllers</span>  <span style="color:var(--muted)">(api/output/controller/)</span>' },
            { text: '        │  book · user · marathon · telegram' },
            { text: '        ↓' },
            { text: '<span style="color:var(--green)">Service Layer</span>     <span style="color:var(--muted)">(service/)</span>' },
            { text: '        │  BookService · AuthenticationService · MarathonService' },
            { text: '        ↓' },
            { text: '<span style="color:var(--yellow)">DAO Layer</span>         <span style="color:var(--muted)">(dao/)</span>' },
            { text: '        │  Spring Data JPA + QueryDSL' },
            { text: '        ↓' },
            { text: '<span style="color:var(--purple)">PostgreSQL</span>' },
            { text: '' },
            { text: '<span style="color:var(--muted)">// external integrations</span>' },
            { text: 'Google Books API · Litres · Goodreads · Mailgun' },
            { text: 'Gemini AI · Telegram · S3 · Social OAuth2' },
          ]} />
        </div>

        <!-- Stats -->
        <div class="block">
          <h2 class="block-title"><span class="muted">##</span> stats</h2>
          <div class="stats-grid">
            {stats.map(s => (
              <div class="stat-item">
                <span class="stat-label">{s.label}</span>
                <span class="stat-value">{s.value}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Features -->
        <div class="block">
          <h2 class="block-title"><span class="muted">##</span> features</h2>
          <div class="features-grid">
            {features.map(f => (
              <div class="feature-item">
                <div class="feature-icon">{f.icon}</div>
                <div>
                  <div class="feature-title">{f.title}</div>
                  <div class="feature-desc">{f.desc}</div>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Key API endpoints -->
        <div class="block">
          <h2 class="block-title"><span class="muted">##</span> api (selected endpoints)</h2>
          <Terminal title="REST endpoints" lines={[
            { text: '<span style="color:var(--muted)">// auth</span>' },
            { prompt: true, text: 'POST /auth/login' },
            { prompt: true, text: 'POST /auth/verify/google|vk|telegram' },
            { text: '' },
            { text: '<span style="color:var(--muted)">// books</span>' },
            { prompt: true, text: 'GET  /books/search' },
            { prompt: true, text: 'GET  /books/google-search' },
            { prompt: true, text: 'POST /books/litres          <span style="color:var(--muted)">// parse from URL</span>' },
            { prompt: true, text: 'POST /books/{id}/review' },
            { text: '' },
            { text: '<span style="color:var(--muted)">// bookshelf</span>' },
            { prompt: true, text: 'GET  /users/{id}/books      <span style="color:var(--muted)">// by section</span>' },
            { prompt: true, text: 'PUT  /users/{id}/books      <span style="color:var(--muted)">// add to shelf</span>' },
            { text: '' },
            { text: '<span style="color:var(--muted)">// marathons</span>' },
            { prompt: true, text: 'POST /marathons' },
            { prompt: true, text: 'PUT  /users/{uid}/marathons/{mid}' },
            { prompt: true, text: 'POST /marathons/{id}/messages' },
          ]} />
        </div>

        <!-- Scheduled jobs -->
        <div class="block">
          <h2 class="block-title"><span class="muted">##</span> scheduled jobs</h2>
          <div class="algo-block">
            <div class="algo-title"><span class="muted">// cron tasks</span></div>
            <div class="algo-body">
              <p><span class="cyan">@hourly</span>   <span style="color:var(--text)">recalculate book aggregate ratings</span></p>
              <p><span class="cyan">@daily</span>    <span style="color:var(--text)">check and close finished marathons</span></p>
              <p><span class="cyan">@monthly</span>  <span style="color:var(--text)">update user activity statistics</span></p>
            </div>
          </div>
        </div>

        <!-- Footer -->
        <div class="page-footer">
          <a href={`${import.meta.env.BASE_URL}/`} class="btn-secondary">← назад на главную</a>
        </div>

      </div>
    </section>

    <footer>
      <div class="container footer-inner">
        <span class="muted">// built with <span class="red">♥</span> using Astro · deployed on GitHub Pages</span>
        <a href="https://github.com/triador" target="_blank" rel="noopener">github.com/triador</a>
      </div>
    </footer>

  </main>
</Layout>

<style>
  .container {
    max-width: 860px;
    margin: 0 auto;
    padding: 0 24px;
  }

  nav {
    position: sticky;
    top: 0;
    z-index: 10;
    background: rgba(13, 17, 23, 0.85);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--border);
    padding: 14px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-logo {
    font-size: 16px;
    font-weight: 700;
    color: var(--text);
    text-decoration: none;
  }
  .nav-logo:hover { text-decoration: none; }

  .blink {
    animation: blink 1s step-end infinite;
    color: var(--green);
  }
  @keyframes blink {
    50% { opacity: 0; }
  }

  .nav-links {
    display: flex;
    gap: 24px;
  }
  .nav-links a {
    color: var(--muted);
    font-size: 13px;
    transition: color 0.2s;
  }
  .nav-links a:hover {
    color: var(--text);
    text-decoration: none;
  }

  .page-header {
    padding: 60px 0 40px;
  }

  .page-label {
    font-size: 13px;
    color: var(--muted);
    margin-bottom: 12px;
  }

  .page-title {
    font-size: clamp(22px, 4vw, 36px);
    font-weight: 700;
    margin-bottom: 10px;
  }

  .page-sub {
    color: var(--muted);
    font-size: 14px;
  }

  .section {
    padding: 0 0 64px;
    border-top: 1px solid var(--border);
  }

  .block {
    padding-top: 48px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .block-title {
    font-size: 18px;
    font-weight: 700;
    color: var(--text);
  }

  .tech-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
  }

  .stat-item {
    background: var(--bg);
    padding: 14px 16px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .stat-label {
    font-size: 11px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .stat-value {
    font-size: 14px;
    font-weight: 600;
    color: var(--cyan);
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 16px;
  }

  .feature-item {
    display: flex;
    gap: 12px;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 14px 16px;
  }

  .feature-icon {
    font-size: 20px;
    flex-shrink: 0;
    line-height: 1;
    margin-top: 2px;
  }

  .feature-title {
    font-weight: 600;
    font-size: 13px;
    margin-bottom: 4px;
    color: var(--text);
  }

  .feature-desc {
    font-size: 12px;
    color: var(--muted);
    line-height: 1.6;
  }

  .algo-block {
    background: #010409;
    border: 1px solid var(--border);
    border-left: 3px solid var(--green);
    border-radius: 8px;
    overflow: hidden;
    font-size: 13px;
  }

  .algo-title {
    padding: 10px 16px;
    border-bottom: 1px solid var(--border);
    color: var(--muted);
    background: var(--bg-card);
  }

  .algo-body {
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    white-space: pre-wrap;
  }

  .algo-body .cyan { color: var(--cyan); }

  .page-footer {
    margin-top: 48px;
  }

  .btn-secondary {
    display: inline-block;
    border: 1px solid var(--border);
    color: var(--muted);
    padding: 8px 18px;
    border-radius: 6px;
    font-size: 13px;
    transition: border-color 0.2s, color 0.2s;
  }
  .btn-secondary:hover {
    border-color: var(--muted);
    color: var(--text);
    text-decoration: none;
  }

  footer {
    border-top: 1px solid var(--border);
    padding: 24px;
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
    font-size: 12px;
  }

  .muted { color: var(--muted); }
  .red   { color: var(--red); }

  @media (max-width: 640px) {
    .footer-inner {
      flex-direction: column;
      text-align: center;
    }
  }
</style>