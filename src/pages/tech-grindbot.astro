---
import Layout from '../layouts/Layout.astro';
import Terminal from '../components/Terminal.astro';
import Badge from '../components/Badge.astro';

const techStack = [
  { name: 'Java 21', color: 'orange' },
  { name: 'Spring Boot', color: 'green' },
  { name: 'PostgreSQL', color: 'cyan' },
  { name: 'Bybit API', color: 'yellow' },
  { name: 'WebSocket', color: 'purple' },
  { name: 'Docker', color: 'cyan' },
  { name: 'Liquibase', color: 'red' },
] as const;

const features = [
  {
    icon: '📐',
    title: 'Grid Strategy Engine',
    desc: 'Calculates operating range from deposit, percent step, and quote per order. Places limit buy/sell orders at each grid level.',
  },
  {
    icon: '🔄',
    title: '8+ Recovery Modes',
    desc: 'Handles price moving below/above grid, reversals, and partial fills. Each scenario has a dedicated recovery handler.',
  },
  {
    icon: '📡',
    title: 'WebSocket Order Tracking',
    desc: 'Real-time order updates from Bybit via WebSocket. Events dispatched to typed handlers per order state.',
  },
  {
    icon: '💰',
    title: 'Flexible Deposits',
    desc: 'Idle USDT automatically subscribed to Bybit lending products. Redeemed on demand when grid needs capital.',
  },
  {
    icon: '🧾',
    title: 'Commission Management',
    desc: 'Buys commission tokens on strategy start. Tracks available commission throughout execution.',
  },
  {
    icon: '🗄️',
    title: 'Persistent State',
    desc: 'Strategy state, order book, and partial fills persisted in PostgreSQL. Survives restarts without data loss.',
  },
];

const stats = [
  { label: 'Language', value: 'Java 21' },
  { label: 'Framework', value: 'Spring Boot 3.4' },
  { label: 'Database', value: 'PostgreSQL 16' },
  { label: 'Exchange', value: 'Bybit' },
  { label: 'Port', value: ':8092' },
  { label: 'Container', value: 'Docker (Alpine)' },
];
---

<Layout title="grindbot — technical details" description="Technical implementation details for the Bybit grid trading bot.">
  <main>

    <!-- NAV -->
    <nav>
      <a href={`${import.meta.env.BASE_URL}/`} class="nav-logo">triador<span class="blink">_</span></a>
      <div class="nav-links">
        <a href={`${import.meta.env.BASE_URL}/`}>← главная</a>
        <a href="https://github.com/triador" target="_blank" rel="noopener">github</a>
      </div>
    </nav>

    <!-- HEADER -->
    <section class="page-header">
      <div class="container">
        <p class="page-label"><span class="muted">~/projects/</span>grindbot</p>
        <h1 class="page-title">Technical Details</h1>
        <p class="page-sub">Grid trading bot for Bybit exchange</p>
      </div>
    </section>

    <!-- CONTENT -->
    <section class="section">
      <div class="container">

        <!-- Stack -->
        <div class="block">
          <h2 class="block-title"><span class="muted">##</span> stack</h2>
          <div class="tech-badges">
            {techStack.map(t => <Badge text={t.name} color={t.color} />)}
          </div>
        </div>

        <!-- Architecture -->
        <div class="block">
          <h2 class="block-title"><span class="muted">##</span> architecture</h2>
          <Terminal title="request flow" lines={[
            { text: '<span style="color:var(--muted)">// order lifecycle</span>' },
            { text: '' },
            { text: 'POST /api/strategy/start' },
            { text: '        │' },
            { text: '        ↓' },
            { text: '<span style="color:var(--cyan)">RunStrategyUseCase</span>' },
            { text: '  ├─ buy commission tokens' },
            { text: '  ├─ place market buy order' },
            { text: '  └─ place limit grid orders' },
            { text: '' },
            { text: '<span style="color:var(--muted)">// real-time updates</span>' },
            { text: '' },
            { text: 'Bybit WebSocket  ──→  <span style="color:var(--purple)">OnOrderEventUseCase</span>' },
            { text: '                              │' },
            { text: '              ┌───────────────┼───────────────┐' },
            { text: '              ↓               ↓               ↓' },
            { text: '   <span style="color:var(--green)">LimitBuyHandler</span>  <span style="color:var(--yellow)">LimitSellHandler</span>  <span style="color:var(--red)">RecoveryHandler</span>' },
            { text: '              └───────────────┼───────────────┘' },
            { text: '                              ↓' },
            { text: '                   <span style="color:var(--yellow)">PostgreSQL</span>' },
            { text: '        <span style="color:var(--muted)">strategy · order_book · partial_fills</span>' },
          ]} />
        </div>

        <!-- Stats -->
        <div class="block">
          <h2 class="block-title"><span class="muted">##</span> stats</h2>
          <div class="stats-grid">
            {stats.map(s => (
              <div class="stat-item">
                <span class="stat-label">{s.label}</span>
                <span class="stat-value">{s.value}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Features -->
        <div class="block">
          <h2 class="block-title"><span class="muted">##</span> features</h2>
          <div class="features-grid">
            {features.map(f => (
              <div class="feature-item">
                <div class="feature-icon">{f.icon}</div>
                <div>
                  <div class="feature-title">{f.title}</div>
                  <div class="feature-desc">{f.desc}</div>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Grid strategy highlight -->
        <div class="block">
          <h2 class="block-title"><span class="muted">##</span> grid strategy example</h2>
          <div class="algo-block">
            <div class="algo-title">
              <span class="muted">// </span>BTC/USDT · deposit 1000 USDT · step 0.5% · 100 USDT per order
            </div>
            <div class="algo-body">
              <p><span class="muted">// price at start: 100 000 USDT</span></p>
              <p></p>
              <p><span class="cyan">sell</span> @ <span class="yellow">100 500</span>  <span class="muted">// +0.5%</span></p>
              <p><span class="cyan">sell</span> @ <span class="yellow">101 005</span>  <span class="muted">// +1.0%</span></p>
              <p><span class="green">◆ current price</span></p>
              <p><span class="purple">buy</span> &nbsp;@ <span class="yellow">99 500</span>   <span class="muted">// -0.5%</span></p>
              <p><span class="purple">buy</span> &nbsp;@ <span class="yellow">99 003</span>   <span class="muted">// -1.0%</span></p>
              <p></p>
              <p><span class="muted">// buy fills → new sell placed one level above</span></p>
              <p><span class="muted">// sell fills → new buy placed one level below</span></p>
            </div>
          </div>
        </div>

        <!-- API -->
        <div class="block">
          <h2 class="block-title"><span class="muted">##</span> api</h2>
          <Terminal title="REST endpoints" lines={[
            { prompt: true, text: 'POST /api/strategy/start' },
            { text: '<span style="color:var(--muted)">// start grid trading with params</span>' },
            { text: '' },
            { prompt: true, text: 'POST /api/strategy/{id}/stop' },
            { text: '<span style="color:var(--muted)">// gracefully halt strategy</span>' },
            { text: '' },
            { prompt: true, text: 'POST /api/strategy/{id}/recover' },
            { text: '<span style="color:var(--muted)">// recover when price leaves grid bounds</span>' },
          ]} />
        </div>

        <!-- Footer -->
        <div class="page-footer">
          <a href={`${import.meta.env.BASE_URL}/`} class="btn-secondary">← назад на главную</a>
        </div>

      </div>
    </section>

    <footer>
      <div class="container footer-inner">
        <span class="muted">// built with <span class="red">♥</span> using Astro · deployed on GitHub Pages</span>
        <a href="https://github.com/triador" target="_blank" rel="noopener">github.com/triador</a>
      </div>
    </footer>

  </main>
</Layout>

<style>
  .container {
    max-width: 860px;
    margin: 0 auto;
    padding: 0 24px;
  }

  nav {
    position: sticky;
    top: 0;
    z-index: 10;
    background: rgba(13, 17, 23, 0.85);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--border);
    padding: 14px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-logo {
    font-size: 16px;
    font-weight: 700;
    color: var(--text);
    text-decoration: none;
  }
  .nav-logo:hover { text-decoration: none; }

  .blink {
    animation: blink 1s step-end infinite;
    color: var(--green);
  }
  @keyframes blink {
    50% { opacity: 0; }
  }

  .nav-links {
    display: flex;
    gap: 24px;
  }
  .nav-links a {
    color: var(--muted);
    font-size: 13px;
    transition: color 0.2s;
  }
  .nav-links a:hover {
    color: var(--text);
    text-decoration: none;
  }

  .page-header {
    padding: 60px 0 40px;
  }

  .page-label {
    font-size: 13px;
    color: var(--muted);
    margin-bottom: 12px;
  }

  .page-title {
    font-size: clamp(22px, 4vw, 36px);
    font-weight: 700;
    margin-bottom: 10px;
  }

  .page-sub {
    color: var(--muted);
    font-size: 14px;
  }

  .section {
    padding: 0 0 64px;
    border-top: 1px solid var(--border);
  }

  .block {
    padding-top: 48px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .block-title {
    font-size: 18px;
    font-weight: 700;
    color: var(--text);
  }

  .tech-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
  }

  .stat-item {
    background: var(--bg);
    padding: 14px 16px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .stat-label {
    font-size: 11px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .stat-value {
    font-size: 14px;
    font-weight: 600;
    color: var(--cyan);
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 16px;
  }

  .feature-item {
    display: flex;
    gap: 12px;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 14px 16px;
  }

  .feature-icon {
    font-size: 20px;
    flex-shrink: 0;
    line-height: 1;
    margin-top: 2px;
  }

  .feature-title {
    font-weight: 600;
    font-size: 13px;
    margin-bottom: 4px;
    color: var(--text);
  }

  .feature-desc {
    font-size: 12px;
    color: var(--muted);
    line-height: 1.6;
  }

  .algo-block {
    background: #010409;
    border: 1px solid var(--border);
    border-left: 3px solid var(--yellow);
    border-radius: 8px;
    overflow: hidden;
    font-size: 13px;
  }

  .algo-title {
    padding: 10px 16px;
    border-bottom: 1px solid var(--border);
    color: var(--muted);
    background: var(--bg-card);
  }

  .algo-body {
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    white-space: pre-wrap;
  }

  .algo-body .cyan   { color: var(--cyan); }
  .algo-body .green  { color: var(--green); }
  .algo-body .yellow { color: var(--yellow); }
  .algo-body .purple { color: var(--purple); }

  .page-footer {
    margin-top: 48px;
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .btn-secondary {
    display: inline-block;
    border: 1px solid var(--border);
    color: var(--muted);
    padding: 8px 18px;
    border-radius: 6px;
    font-size: 13px;
    transition: border-color 0.2s, color 0.2s;
  }
  .btn-secondary:hover {
    border-color: var(--muted);
    color: var(--text);
    text-decoration: none;
  }

  footer {
    border-top: 1px solid var(--border);
    padding: 24px;
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
    font-size: 12px;
  }

  .muted { color: var(--muted); }
  .red   { color: var(--red); }

  @media (max-width: 640px) {
    .footer-inner {
      flex-direction: column;
      text-align: center;
    }
  }
</style>