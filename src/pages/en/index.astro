---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="triador — software engineer" description="I build products that make life easier.">
  <main>

    <!-- NAV -->
    <nav>
      <span class="nav-logo">triador<span class="blink">_</span></span>
      <div class="nav-links">
        <a href="#projects">projects</a>
        <span class="lang-switch">
          <a href={`${import.meta.env.BASE_URL}/ru/`}>RU</a>
          <span class="sep">/</span>
          <span class="lang-active">EN</span>
        </span>
      </div>
    </nav>

    <!-- HERO -->
    <section class="hero">
      <div class="container">
        <p class="hero-label">👋 hey</p>
        <h1 class="hero-title">I'm <span class="accent">triador</span></h1>
        <p class="hero-sub">
          I build products that make my life easier.<br/>
          Maybe they'll be useful to someone else too.
        </p>
      </div>
    </section>

    <!-- PROJECTS -->
    <section id="projects" class="section">
      <div class="container">
        <h2 class="section-title">Projects</h2>

        <div class="project-card">
          <div class="project-header">
            <div>
              <h3 class="project-name"><a href="https://t.me/TriadorFinanceManagerBot" target="_blank" rel="noopener">Finance Manager</a></h3>
              <p class="project-tagline">Telegram bot for shared expenses</p>
            </div>
            <div class="project-badge">
              <span class="status-dot"></span> live
            </div>
          </div>

          <p class="project-desc">
            I built this bot to simplify tracking shared expenses when traveling with friends, going out together, or just splitting costs.
            The easiest way to use it is to add it to a group chat.
          </p>

          <div class="features-list">
            <div class="feature-item">
              <span class="feature-icon">💸</span>
              <div>
                <div class="feature-title">Tracks expenses</div>
                <div class="feature-desc">
                  Just send an amount or an amount with a comment:
                  <span class="example-tags">
                    <code>1500</code><code>39.90 taxi</code><code>24 + 32 + 20 cafe</code>
                  </span>
                </div>
              </div>
            </div>
            <div class="feature-item">
              <span class="feature-icon">🧾</span>
              <div>
                <div class="feature-title">Reads receipts</div>
                <div class="feature-desc">Send a photo of a receipt instead of entering items manually.</div>
              </div>
            </div>
            <div class="feature-item">
              <span class="feature-icon">🔁</span>
              <div>
                <div class="feature-title">Minimizes transfers</div>
                <div class="feature-desc">Optimizes debts to reduce the number of transfers between participants.</div>
              </div>
            </div>
            <div class="feature-item">
              <span class="feature-icon">📅</span>
              <div>
                <div class="feature-title">Keeps expense history</div>
                <div class="feature-desc">Browse expenses for any month.</div>
              </div>
            </div>
          </div>

          <div class="project-footer">
            <a href={`${import.meta.env.BASE_URL}/en/tech`} class="btn-secondary">technical details →</a>
            <a href="https://t.me/TriadorFinanceManagerBot" target="_blank" rel="noopener" class="btn-primary">open bot →</a>
          </div>
        </div>

        <!-- PROJECT CARD: grindbot -->
        <div class="project-card">
          <div class="project-header">
            <div>
              <h3 class="project-name"><a href="https://t.me/GridTeamBot" target="_blank" rel="noopener">Grindbot</a></h3>
              <p class="project-tagline">Trading bot for Bybit exchange</p>
            </div>
            <div class="project-badge">
              <span class="status-dot"></span> live
            </div>
          </div>

          <p class="project-desc">
            I built this bot to automate crypto trading without having to watch the market manually.
          </p>

          <div class="features-list">
            <div class="feature-item">
              <span class="feature-icon">📊</span>
              <div>
                <div class="feature-title">Grid strategy</div>
                <div class="feature-desc">Places buy and sell orders at price levels within a grid trading strategy.</div>
              </div>
            </div>
            <div class="feature-item">
              <span class="feature-icon">🏦</span>
              <div>
                <div class="feature-title">Puts idle funds to work</div>
                <div class="feature-desc">Keeps the free portion of the balance in an exchange lending product to maximize returns.</div>
              </div>
            </div>
          </div>

          <div class="project-footer">
            <a href={`${import.meta.env.BASE_URL}/en/tech-grindbot`} class="btn-secondary">technical details →</a>
            <a href="https://t.me/GridTeamBot" target="_blank" rel="noopener" class="btn-primary">open bot →</a>
          </div>
        </div>

        <!-- PROJECT CARD: bookey -->
        <div class="project-card">
          <div class="project-header">
            <div>
              <h3 class="project-name"><a href="https://bookey.ru/" target="_blank" rel="noopener">Bookey</a></h3>
              <p class="project-tagline">Book list tracker</p>
            </div>
            <div class="project-badge">
              <span class="status-dot"></span> live
            </div>
          </div>

          <p class="project-desc">
            I built this to keep track of what I'm reading, what I've finished, and what I want to read.
            Over time it grew to include ratings, reviews, and reading marathons.
          </p>

          <div class="features-list">
            <div class="feature-item">
              <span class="feature-icon">📚</span>
              <div>
                <div class="feature-title">Personal shelf</div>
                <div class="feature-desc">Organize books by status: reading, finished, want to read.</div>
              </div>
            </div>
            <div class="feature-item">
              <span class="feature-icon">🔗</span>
              <div>
                <div class="feature-title">Add from a link</div>
                <div class="feature-desc">Can't find a book? Paste a link from Litres or Goodreads and the service pulls the data automatically.</div>
              </div>
            </div>
            <div class="feature-item">
              <span class="feature-icon">⭐</span>
              <div>
                <div class="feature-title">Ratings and reviews</div>
                <div class="feature-desc">Rate any book and write a review.</div>
              </div>
            </div>
            <div class="feature-item">
              <span class="feature-icon">🏃</span>
              <div>
                <div class="feature-title">Marathons</div>
                <div class="feature-desc">Read together with others and discuss books inside the marathon.</div>
              </div>
            </div>
          </div>

          <div class="project-footer">
            <a href={`${import.meta.env.BASE_URL}/en/tech-bookey`} class="btn-secondary">technical details →</a>
            <a href="https://bookey.ru/" target="_blank" rel="noopener" class="btn-primary">open service →</a>
          </div>
        </div>

      </div>
    </section>

    <!-- COFFEE -->
    <section class="section coffee-section">
      <div class="container">
        <p class="coffee-text">
          If any of these turned out useful — feel free to buy me a coffee ☕
        </p>
        <div class="coffee-items">
          <div class="coffee-item">
            <span class="coffee-label">USDT (TON)</span>
            <code class="coffee-addr">UQCVRBwdjVFDj1XZa412b0y1H8seJjx9tWLCyza_qorVau36</code>
          </div>
        </div>
      </div>
    </section>

    <!-- FOOTER -->
    <footer>
      <div class="container footer-inner">
        <span class="muted">made with heart</span>
      </div>
    </footer>

  </main>
</Layout>

<style>
  .container {
    max-width: 860px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* ── Nav ── */
  nav {
    position: sticky;
    top: 0;
    z-index: 10;
    background: rgba(13, 17, 23, 0.85);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--border);
    padding: 14px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-logo {
    font-size: 16px;
    font-weight: 700;
    color: var(--text);
  }

  .blink {
    animation: blink 1s step-end infinite;
    color: var(--green);
  }
  @keyframes blink {
    50% { opacity: 0; }
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 24px;
  }
  .nav-links a {
    color: var(--muted);
    font-size: 13px;
    transition: color 0.2s;
  }
  .nav-links a:hover {
    color: var(--text);
    text-decoration: none;
  }

  .lang-switch {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 13px;
  }
  .lang-active {
    color: var(--text);
    font-weight: 600;
  }
  .sep {
    color: var(--border);
  }

  /* ── Hero ── */
  .hero {
    padding: 80px 0 60px;
  }

  .hero-label {
    font-size: 18px;
    margin-bottom: 16px;
  }

  .hero-title {
    font-size: clamp(28px, 5vw, 48px);
    font-weight: 700;
    margin-bottom: 20px;
    line-height: 1.2;
  }

  .accent {
    color: var(--cyan);
  }

  .hero-sub {
    color: var(--muted);
    font-size: 15px;
    line-height: 1.9;
    max-width: 520px;
  }

  /* ── Section ── */
  .section {
    padding: 64px 0;
    border-top: 1px solid var(--border);
  }

  .section-title {
    font-size: 22px;
    font-weight: 700;
    margin-bottom: 28px;
    color: var(--text);
  }

  /* ── Project card ── */
  .project-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .project-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 16px;
  }

  .project-name {
    font-size: 20px;
    font-weight: 700;
    color: var(--text);
  }
  .project-name a {
    color: inherit;
    text-decoration: none;
  }
  .project-name a:hover {
    color: var(--cyan);
  }

  .project-tagline {
    color: var(--muted);
    font-size: 13px;
    margin-top: 4px;
  }

  .project-badge {
    display: flex;
    align-items: center;
    gap: 6px;
    color: var(--green);
    font-size: 12px;
    white-space: nowrap;
    border: 1px solid var(--green);
    padding: 4px 10px;
    border-radius: 20px;
    background: #3fb95010;
  }

  .status-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--green);
    animation: pulse 2s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.4; }
  }

  .project-desc {
    color: var(--muted);
    font-size: 14px;
    line-height: 1.9;
  }

  /* ── Features ── */
  .features-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .feature-item {
    display: flex;
    gap: 14px;
    align-items: flex-start;
  }

  .feature-icon {
    font-size: 22px;
    flex-shrink: 0;
    line-height: 1;
    margin-top: 1px;
  }

  .feature-title {
    font-weight: 600;
    font-size: 14px;
    margin-bottom: 2px;
    color: var(--text);
  }

  .feature-desc {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.6;
  }

  .example-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    margin-top: 6px;
  }

  .example-tags code {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 2px 7px;
    font-size: 12px;
    font-family: inherit;
    color: var(--muted);
  }

  /* ── Project footer ── */
  .project-footer {
    display: flex;
    justify-content: flex-end;
    gap: 12px;
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-block;
    border: 1px solid var(--cyan);
    color: var(--cyan);
    padding: 8px 18px;
    border-radius: 6px;
    font-size: 13px;
    transition: background 0.2s, color 0.2s;
    text-decoration: none;
  }
  .btn-primary:hover {
    background: var(--cyan);
    color: #0d1117;
    text-decoration: none;
  }

  .btn-secondary {
    display: inline-block;
    border: 1px solid var(--border);
    color: var(--muted);
    padding: 8px 18px;
    border-radius: 6px;
    font-size: 13px;
    transition: border-color 0.2s, color 0.2s;
  }
  .btn-secondary:hover {
    border-color: var(--muted);
    color: var(--text);
    text-decoration: none;
  }

  /* ── Footer ── */
  footer {
    border-top: 1px solid var(--border);
    padding: 24px;
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
    font-size: 12px;
  }

  .muted { color: var(--muted); }

  /* ── Coffee ── */
  .coffee-section {
    padding: 40px 0;
  }
  .coffee-text {
    color: var(--muted);
    font-size: 14px;
    margin-bottom: 16px;
  }
  .coffee-items {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .coffee-item {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }
  .coffee-label {
    font-size: 13px;
    color: var(--muted);
    min-width: 100px;
  }
  .coffee-addr {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 4px 10px;
    font-size: 13px;
    font-family: inherit;
    color: var(--text);
    word-break: break-all;
  }

  /* ── Responsive ── */
  @media (max-width: 640px) {
    .project-header {
      flex-direction: column;
    }
    .project-footer {
      justify-content: flex-start;
    }
    .footer-inner {
      flex-direction: column;
      text-align: center;
    }
  }
</style>