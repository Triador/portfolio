---
import Layout from '../layouts/Layout.astro';
import Terminal from '../components/Terminal.astro';
import Badge from '../components/Badge.astro';

const techStack = [
  { name: 'Go', color: 'cyan' },
  { name: 'SQLite', color: 'yellow' },
  { name: 'Telegram Bot API', color: 'purple' },
  { name: 'Webhooks', color: 'green' },
  { name: 'WAL', color: 'orange' },
] as const;

const features = [
  {
    icon: '💸',
    title: 'Expense Tracking',
    desc: 'Record who paid what and for whom. Supports arbitrary amounts with optional descriptions.',
  },
  {
    icon: '⚖️',
    title: 'Split Evenly',
    desc: 'One person pays — cost splits equally among others. Remainder distributed automatically.',
  },
  {
    icon: '🔁',
    title: 'Cycle Elimination',
    desc: 'DFS-based algorithm automatically cancels circular debts. A→B→C→A with equal amounts resolves to zero.',
  },
  {
    icon: '📊',
    title: 'Debt Matrix',
    desc: '/stat command shows current state: who owes what to whom across the entire group.',
  },
  {
    icon: '📅',
    title: 'Transaction History',
    desc: 'Monthly logs via /history. Browse up to 12 months of operations with timestamps.',
  },
  {
    icon: '🧮',
    title: 'Precise Arithmetic',
    desc: 'All amounts stored in integer cents — no floating-point errors. Handles comma/period decimals.',
  },
];

const stats = [
  { label: 'Language', value: 'Go 1.23' },
  { label: 'Database', value: 'SQLite (WAL)' },
  { label: 'Source files', value: '8 .go files' },
  { label: 'Architecture', value: 'Webhook server' },
  { label: 'Port', value: ':58823' },
  { label: 'Tests', value: 'Unit + Integration' },
];
---

<Layout title="finance-manager — technical details" description="Technical implementation details for the finance-manager Telegram bot.">
  <main>

    <!-- NAV -->
    <nav>
      <a href={`${import.meta.env.BASE_URL}/`} class="nav-logo">triador<span class="blink">_</span></a>
      <div class="nav-links">
        <a href={`${import.meta.env.BASE_URL}/`}>← главная</a>
        <a href="https://github.com/triador" target="_blank" rel="noopener">github</a>
      </div>
    </nav>

    <!-- HEADER -->
    <section class="page-header">
      <div class="container">
        <p class="page-label"><span class="muted">~/projects/</span>finance-manager</p>
        <h1 class="page-title">Technical Details</h1>
        <p class="page-sub">Implementation notes for the Telegram debt-splitting bot</p>
      </div>
    </section>

    <!-- CONTENT -->
    <section class="section">
      <div class="container">

        <!-- Stack & Overview -->
        <div class="block">
          <h2 class="block-title"><span class="muted">##</span> stack</h2>
          <div class="tech-badges">
            {techStack.map(t => <Badge text={t.name} color={t.color} />)}
          </div>
        </div>

        <!-- Architecture -->
        <div class="block">
          <h2 class="block-title"><span class="muted">##</span> architecture</h2>
          <Terminal title="request flow" lines={[
            { text: '<span style="color:var(--muted)">// request flow</span>' },
            { text: '' },
            { text: 'Telegram  ──→  Webhook <span style="color:var(--muted)">(:58823)</span>' },
            { text: '                  │' },
            { text: '          ┌───────┴────────┐' },
            { text: '          ↓                ↓' },
            { text: '   <span style="color:var(--cyan)">Command Router</span>    <span style="color:var(--purple)">Callback Handler</span>' },
            { text: '          │                │' },
            { text: '          └───────┬────────┘' },
            { text: '                  ↓' },
            { text: '          <span style="color:var(--yellow)">SQLite (WAL mode)</span>' },
            { text: '          <span style="color:var(--muted)">chats · members · debts · transactions</span>' },
          ]} />
        </div>

        <!-- Stats -->
        <div class="block">
          <h2 class="block-title"><span class="muted">##</span> stats</h2>
          <div class="stats-grid">
            {stats.map(s => (
              <div class="stat-item">
                <span class="stat-label">{s.label}</span>
                <span class="stat-value">{s.value}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Features -->
        <div class="block">
          <h2 class="block-title"><span class="muted">##</span> features</h2>
          <div class="features-grid">
            {features.map(f => (
              <div class="feature-item">
                <div class="feature-icon">{f.icon}</div>
                <div>
                  <div class="feature-title">{f.title}</div>
                  <div class="feature-desc">{f.desc}</div>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Cycle elimination -->
        <div class="block">
          <h2 class="block-title"><span class="muted">##</span> cycle elimination algorithm</h2>
          <div class="algo-block">
            <div class="algo-title">
              <span class="muted">// </span>cycle elimination algorithm
            </div>
            <div class="algo-body">
              <p><span class="muted">// example: 3 people, A owes B, B owes C, C owes A — 30 each</span></p>
              <p><span class="cyan">before</span>: A→B <span class="yellow">30</span>, B→C <span class="yellow">30</span>, C→A <span class="yellow">30</span></p>
              <p><span class="green">after</span> &nbsp;: <span class="muted">all debts resolved to 0</span></p>
              <p>&nbsp;</p>
              <p><span class="muted">// DFS finds minimum edge in cycle, subtracts from all edges</span></p>
              <p><span class="muted">// iterates until no cycles remain — O(V·E) worst case</span></p>
            </div>
          </div>
        </div>

        <!-- Go terminal -->
        <div class="block">
          <h2 class="block-title"><span class="muted">##</span> environment</h2>
          <Terminal title="go version" lines={[
            { prompt: true, text: 'go version' },
            { text: 'go version go1.23.0 windows/amd64', color: 'green' },
            { text: '' },
            { prompt: true, text: 'go env GOOS GOARCH' },
            { text: 'windows' },
            { text: 'amd64' },
          ]} />
        </div>

        <!-- Source link -->
        <div class="page-footer">
          <a href="https://github.com/triador/finance-manager" target="_blank" rel="noopener" class="btn-outline">
            view source on github →
          </a>
          <a href={`${import.meta.env.BASE_URL}/`} class="btn-secondary">← назад на главную</a>
        </div>

      </div>
    </section>

    <footer>
      <div class="container footer-inner">
        <span class="muted">// built with <span class="red">♥</span> using Astro · deployed on GitHub Pages</span>
        <a href="https://github.com/triador" target="_blank" rel="noopener">github.com/triador</a>
      </div>
    </footer>

  </main>
</Layout>

<style>
  .container {
    max-width: 860px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* ── Nav ── */
  nav {
    position: sticky;
    top: 0;
    z-index: 10;
    background: rgba(13, 17, 23, 0.85);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--border);
    padding: 14px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-logo {
    font-size: 16px;
    font-weight: 700;
    color: var(--text);
    text-decoration: none;
  }
  .nav-logo:hover { text-decoration: none; }

  .blink {
    animation: blink 1s step-end infinite;
    color: var(--green);
  }
  @keyframes blink {
    50% { opacity: 0; }
  }

  .nav-links {
    display: flex;
    gap: 24px;
  }
  .nav-links a {
    color: var(--muted);
    font-size: 13px;
    transition: color 0.2s;
  }
  .nav-links a:hover {
    color: var(--text);
    text-decoration: none;
  }

  /* ── Page header ── */
  .page-header {
    padding: 60px 0 40px;
  }

  .page-label {
    font-size: 13px;
    color: var(--muted);
    margin-bottom: 12px;
  }

  .page-title {
    font-size: clamp(22px, 4vw, 36px);
    font-weight: 700;
    margin-bottom: 10px;
  }

  .page-sub {
    color: var(--muted);
    font-size: 14px;
  }

  /* ── Section ── */
  .section {
    padding: 0 0 64px;
    border-top: 1px solid var(--border);
  }

  /* ── Block ── */
  .block {
    padding-top: 48px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .block-title {
    font-size: 18px;
    font-weight: 700;
    color: var(--text);
  }

  /* ── Tech badges ── */
  .tech-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  /* ── Stats ── */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
  }

  .stat-item {
    background: var(--bg);
    padding: 14px 16px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .stat-label {
    font-size: 11px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .stat-value {
    font-size: 14px;
    font-weight: 600;
    color: var(--cyan);
  }

  /* ── Features ── */
  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 16px;
  }

  .feature-item {
    display: flex;
    gap: 12px;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 14px 16px;
  }

  .feature-icon {
    font-size: 20px;
    flex-shrink: 0;
    line-height: 1;
    margin-top: 2px;
  }

  .feature-title {
    font-weight: 600;
    font-size: 13px;
    margin-bottom: 4px;
    color: var(--text);
  }

  .feature-desc {
    font-size: 12px;
    color: var(--muted);
    line-height: 1.6;
  }

  /* ── Algo block ── */
  .algo-block {
    background: #010409;
    border: 1px solid var(--border);
    border-left: 3px solid var(--purple);
    border-radius: 8px;
    overflow: hidden;
    font-size: 13px;
  }

  .algo-title {
    padding: 10px 16px;
    border-bottom: 1px solid var(--border);
    color: var(--muted);
    background: var(--bg-card);
  }

  .algo-body {
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    white-space: pre-wrap;
  }

  .algo-body .cyan   { color: var(--cyan); }
  .algo-body .green  { color: var(--green); }
  .algo-body .yellow { color: var(--yellow); }

  /* ── Page footer ── */
  .page-footer {
    margin-top: 48px;
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .btn-outline {
    display: inline-block;
    border: 1px solid var(--border);
    color: var(--text);
    padding: 8px 18px;
    border-radius: 6px;
    font-size: 13px;
    transition: border-color 0.2s, color 0.2s;
  }
  .btn-outline:hover {
    border-color: var(--cyan);
    color: var(--cyan);
    text-decoration: none;
  }

  .btn-secondary {
    display: inline-block;
    border: 1px solid var(--border);
    color: var(--muted);
    padding: 8px 18px;
    border-radius: 6px;
    font-size: 13px;
    transition: border-color 0.2s, color 0.2s;
  }
  .btn-secondary:hover {
    border-color: var(--muted);
    color: var(--text);
    text-decoration: none;
  }

  /* ── Footer ── */
  footer {
    border-top: 1px solid var(--border);
    padding: 24px;
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
    font-size: 12px;
  }

  .muted { color: var(--muted); }
  .red   { color: var(--red); }

  @media (max-width: 640px) {
    .footer-inner {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
