---
interface Props {
  text: string;
  color?: 'green' | 'cyan' | 'yellow' | 'purple' | 'red' | 'orange';
}
const { text, color = 'cyan' } = Astro.props;
---
<span class={`badge badge-${color}`}>{text}</span>

<style>
  .badge {
    display: inline-block;
    padding: 2px 10px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 600;
    border: 1px solid;
    white-space: nowrap;
  }
  .badge-green  { color: var(--green);  border-color: var(--green);  background: #3fb95015; }
  .badge-cyan   { color: var(--cyan);   border-color: var(--cyan);   background: #79c0ff15; }
  .badge-yellow { color: var(--yellow); border-color: var(--yellow); background: #e3b34115; }
  .badge-purple { color: var(--purple); border-color: var(--purple); background: #bc8cff15; }
  .badge-red    { color: var(--red);    border-color: var(--red);    background: #ff7b7215; }
  .badge-orange { color: var(--orange); border-color: var(--orange); background: #ffa65715; }
</style>
